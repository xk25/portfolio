---
const data = [
  {
    position: "SDE Intern",
    company: "Playpowerlabs",
    duration: "Mar'24 - Jul'24",
    description:
      "During my internship, I worked with agile teams using Git, Angular and NestJS.",
  },
];
---

<section aria-labelledby="experience-heading">
  <h2 class="text-2xl font-medium tracking-tight text-white mb-3">
    Experience
  </h2>

  <div class="flex flex-col gap-4">
    {
      data.map((exp) => (
        <article class="group relative flex flex-col items-start gap-0.5">
          <div class="flex flex-col sm:flex-row sm:items-center justify-between w-full gap-1">
            <h3 class="text-lg font-medium text-stone-200">
              {exp.position}
            </h3>
            <span class="text-sm font-medium text-stone-500 whitespace-nowrap">{exp.duration}</span>
          </div>
          <p class="text-base font-normal text-orange-300/70">{exp.company}</p>
          {exp.description && (
            <div class="mt-1.5 text-base leading-relaxed text-stone-400 font-normal w-full">
              {exp.description}
            </div>
          )}
        </article>
      ))
    }
  </div>
</section>
