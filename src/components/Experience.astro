---
const data = [
  {
    position: "SDE Intern",
    company: "Playpowerlabs",
    duration: "Mar'24 - Jul'24",
    description:
      "During my internship, I worked with agile teams using Git, Angular and NestJS.",
  },
];
---

<section aria-labelledby="experience-heading">
  <h1 class="text-2xl font-semibold tracking-wide text-slate-100 md:text-3xl">
    Experience
  </h1>

  <div class="my-2 flex flex-col gap-4">
    {
      data.map((exp) => (
        <article>
          <div class="flex flex-wrap justify-between gap-x-5 gap-y-1">
            <div>
              <h2 class="text-base font-semibold text-slate-100 md:text-lg">
                {exp.position}
              </h2>
              <p class="text-slate-200/90">{exp.company}</p>
            </div>
            <div class="whitespace-nowrap text-sm text-slate-300">
              {exp.duration}
            </div>
          </div>
          {exp.description && (
            <p class="mt-1 text-sm leading-relaxed text-slate-300/90">
              {exp.description}
            </p>
          )}
        </article>
      ))
    }
  </div>
</section>
