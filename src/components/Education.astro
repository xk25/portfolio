---
const data = [
  {
    degree: "M.Tech in Computer Science and Engineering",
    institute: "Indian Institute of Technology, Bombay",
    grade: "9.41/10",
    duration: "2024 - 2026",
    description: "",
    //   "Worked on advanced coursework and research in core computer science areas, with a focus on problem solving, systems thinking, and applied engineering.",
  },
  {
    degree: "B.E. in Computer Engineering",
    institute: "L.D. College of Engineering",
    grade: "8.39/10",
    duration: "2020 - 2024",
  },
];
---

<section aria-labelledby="education-heading">
  <h2 class="text-2xl font-medium tracking-tight text-white mb-3">Education</h2>

  <div class="flex flex-col gap-4">
    {
      data.map((education) => (
        <article class="group relative flex flex-col items-start gap-1">
          <div class="flex flex-col sm:flex-row sm:items-center justify-between w-full gap-1">
            <h3 class="text-lg font-medium text-stone-200">
              {education.degree}
            </h3>
            <span class="text-sm font-medium text-stone-500 whitespace-nowrap">
              {education.duration}
            </span>
          </div>
          <div class="flex flex-col sm:flex-row sm:items-center gap-2">
            <p class="text-base font-normal text-orange-300/70">
              {education.institute}
            </p>
            <span class="inline-block w-fit text-xs font-medium px-2 py-0.5 bg-stone-800/50 text-stone-300 rounded-md border border-stone-700/50 transition-all duration-200 ease-out cursor-default  hover:bg-stone-800/80 hover:text-orange-300 hover:border-orange-400/40 ">
              Grade: {education.grade}
            </span>
          </div>
          {education.description && (
            <div class="mt-1.5 text-base leading-relaxed text-stone-400 font-normal w-full">
              {education.description}
            </div>
          )}
        </article>
      ))
    }
  </div>
</section>
